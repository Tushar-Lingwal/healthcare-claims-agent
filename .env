# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Options: stub | gemini | groq | openai | anthropic
# stub    = no API key needed, uses structured_data only (good for testing)
# gemini  = Google Gemini, free tier — get key at aistudio.google.com
# groq    = Groq/LLaMA, free tier  — get key at console.groq.com
# openai  = OpenAI GPT             — get key at platform.openai.com
# anthropic = Claude               — get key at console.anthropic.com

LLM_PROVIDER=groq

# ─── API Keys (only fill in the one you are using) ────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

GROQ_API_KEY=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
GROQ_MODEL=llama-3.1-8b-instant

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── PHI Token Vault ──────────────────────────────────────────────────────────
# Generate key: python -c "import secrets; print(secrets.token_hex(32))"
VAULT_BACKEND=sqlite
PHI_VAULT_KEY=873c24aaa5c69f021d57fe34dd4056e523636ff23e56f53b8da74588b01d846f
PHI_VAULT_SQLITE_PATH=./vault.sqlite

# ─── Audit Logger ─────────────────────────────────────────────────────────────
AUDIT_BACKEND=sqlite
AUDIT_SQLITE_PATH=./audit.sqlite

# ─── RAG ──────────────────────────────────────────────────────────────────────
RAG_BACKEND=local

# ─── PostgreSQL (production only) ─────────────────────────────────────────────
DATABASE_URL=

# ─── FastAPI App ──────────────────────────────────────────────────────────────
ENV=development
API_HOST=0.0.0.0
API_PORT=8000